<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Qualis — Data Quality Report — {{ dataset }}</title>
<style>
:root {
    --q-neutral-900: #0f172a;
    --q-neutral-400: #94a3b8;
    --q-neutral-50: #f8fafc;
    --q-pass: #16a34a;
    --q-warn: #d97706;
    --q-fail: #dc2626;
    --q-accent: #7c3aed;
    --q-surface: #ffffff;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--q-neutral-50);
    color: var(--q-neutral-900);
    min-height: 100vh;
}

/* ── Hero ────────────────────────────────────────────────────── */
.hero {
    background: {{ hero_color }};
    color: #fff;
    text-align: center;
    padding: 56px 24px 48px;
}

.hero__score {
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    font-size: 96px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -2px;
}

.hero__label {
    margin-top: 16px;
    font-size: 18px;
    opacity: 0.9;
    font-weight: 500;
    letter-spacing: 0.02em;
}

.hero__meta {
    margin-top: 10px;
    font-size: 14px;
    opacity: 0.75;
}

/* ── Layout ──────────────────────────────────────────────────── */
.container {
    max-width: 820px;
    margin: 0 auto;
    padding: 40px 24px 80px;
}

.section-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--q-neutral-400);
    margin-bottom: 16px;
}

/* ── Dimension rows ──────────────────────────────────────────── */
.dimensions {
    background: var(--q-surface);
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    overflow: hidden;
    margin-top: 32px;
}

.dim-row {
    border-bottom: 1px solid #f1f5f9;
}

.dim-row:last-child {
    border-bottom: none;
}

.dim-header {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
}

.dim-header:hover {
    background: #f8fafc;
}

.dim-name {
    font-weight: 600;
    font-size: 14px;
    text-transform: capitalize;
    display: flex;
    align-items: center;
    gap: 8px;
}

.dim-name .chevron {
    display: inline-block;
    font-size: 10px;
    color: var(--q-neutral-400);
    transition: transform 0.2s;
}

.dim-row.open .chevron {
    transform: rotate(90deg);
}

.dim-bar-wrap {
    position: relative;
    height: 6px;
    background: #e2e8f0;
    border-radius: 99px;
    overflow: hidden;
}

.dim-bar-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    border-radius: 99px;
    background: {{ 'var(--q-pass)' }};
}

.dim-score {
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    text-align: right;
    min-width: 110px;
}

.dim-score--pass { color: var(--q-pass); }
.dim-score--warn { color: var(--q-warn); }
.dim-score--fail { color: var(--q-fail); }
.dim-score--none { color: var(--q-neutral-400); font-style: italic; font-family: inherit; }

/* ── Drilldown ───────────────────────────────────────────────── */
.drilldown {
    display: none;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    padding: 0;
}

.dim-row.open .drilldown {
    display: block;
}

.drilldown table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.drilldown th {
    text-align: left;
    padding: 8px 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--q-neutral-400);
    border-bottom: 1px solid #e2e8f0;
    background: #f1f5f9;
}

.drilldown td {
    padding: 10px 20px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
}

.drilldown tr:last-child td {
    border-bottom: none;
}

.drilldown tr.row-fail {
    background: #fef2f2;
}

.drilldown tr.row-fail:hover {
    background: #fee2e2;
}

.drilldown tr.row-pass:hover {
    background: #f0fdf4;
}

.chip {
    display: inline-block;
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.04em;
}

.chip--pass { background: #dcfce7; color: #15803d; }
.chip--fail { background: #fee2e2; color: #b91c1c; }

.rule-id {
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
    font-size: 12px;
    color: var(--q-accent);
}

/* ── Footer ──────────────────────────────────────────────────── */
.footer {
    margin-top: 48px;
    text-align: center;
    font-size: 12px;
    color: var(--q-neutral-400);
}

.footer strong {
    color: var(--q-accent);
}
</style>
</head>
<body>

<!-- ── Hero section ─────────────────────────────────────────── -->
<div class="hero">
    <div class="hero__score">{{ score_pct }}</div>
    <div class="hero__label">Overall Data Quality Score</div>
    <div class="hero__meta">
        {{ passing_dimensions }} of {{ total_dimensions }} dimensions passing
        &mdash;
        {{ critical_violations }} critical violation{% if critical_violations != 1 %}s{% endif %}
    </div>
</div>

<!-- ── Dimension breakdown ───────────────────────────────────── -->
<div class="container">
    <p class="section-title">DAMA Dimension Breakdown</p>

    <div class="dimensions">
        {% for dim in dimensions %}
        <div class="dim-row" id="dim-{{ loop.index }}">
            <div class="dim-header" onclick="toggleDim('dim-{{ loop.index }}')">
                <div class="dim-name">
                    <span class="chevron">&#9658;</span>
                    {{ dim.name }}
                </div>
                {% if dim.measured %}
                <div class="dim-bar-wrap">
                    <div class="dim-bar-fill" style="width: {{ dim.score_pct }}%; background: {{ dim.bar_color }};"></div>
                </div>
                <div class="dim-score dim-score--{{ dim.score_class }}">
                    {{ dim.score_pct }}% &nbsp; {{ dim.passed }}/{{ dim.total }}
                </div>
                {% else %}
                <div></div>
                <div class="dim-score dim-score--none">— not measured</div>
                {% endif %}
            </div>

            {% if dim.checks %}
            <div class="drilldown">
                <table>
                    <thead>
                        <tr>
                            <th>Rule ID</th>
                            <th>Rule Name</th>
                            <th>Status</th>
                            <th style="text-align:right">Violations</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for check in dim.checks %}
                        <tr class="{{ 'row-fail' if not check.passed else 'row-pass' }}">
                            <td><span class="rule-id">{{ check.rule_id }}</span></td>
                            <td>{{ check.rule_name }}</td>
                            <td>
                                <span class="chip chip--{{ 'fail' if not check.passed else 'pass' }}">
                                    {{ 'FAIL' if not check.passed else 'PASS' }}
                                </span>
                            </td>
                            <td style="text-align:right; font-family: 'JetBrains Mono','Fira Code','SF Mono',monospace; font-size:13px;">
                                {{ check.violation_count }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        </div>
        {% endfor %}
    </div>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <div class="footer">
        Generated by <strong>Qualis v{{ version }}</strong>
        &mdash; {{ generated_at }}
    </div>
</div>

<script>
function toggleDim(id) {
    var row = document.getElementById(id);
    if (row) row.classList.toggle('open');
}
</script>
</body>
</html>
